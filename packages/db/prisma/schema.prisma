// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}


model User {
  id            String   @id @default(uuid())
  username      String   @unique
  password      String
  orders        Order[]
  balance       Balance[]
  position      Position[]
  maker_fills   Fill[] @relation("maker_user")
  taker_fills   Fill[] @relation("taker_user")
}

model Market{
  id            String   @id @default(uuid())
  slug          String   @unique
  imageUrl      String
}


model Order{
  id            String   @id @default(uuid())
  userId        String
  marketId      String
  orderType     OrderType
  side          Side
  price         String?
  slippage      Int?
  qty           String
  initialMargin String
  filledQty     String
  status        OrderStatus
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt()
  maker_fills   Fill[]  @relation("maker")
  taker_fills   Fill[]   @relation("taker")
  user          User @relation(fields: [userId], references: [id])
}

enum OrderStatus {
  OPEN
  FILLED
  PARTIALLY_FILLED
  CANCELLED

}
enum Side {
  BUY
  SELL
}

enum OrderType {
  MARKET
  LIMIT
}


model Fill{
  id              String   @id @default(uuid())
  maker_id        String
  taker_id        String
  qty             String
  price           String
  maker_order_id  String
  taker_order_id  String
  market_id       String
  createdAt       DateTime @default(now())
  maker_order     Order @relation("maker",fields: [maker_order_id], references: [id])
  taker_order     Order @relation("taker",fields: [taker_order_id], references: [id])
  maker_user      User @relation("maker_user",fields: [maker_id], references: [id])
  taker_user      User @relation("taker_user",fields: [taker_id], references: [id])
}


model Balance {
  id           String @id @default(uuid())
  userId       String
  asset        String
  available    Decimal
  locked       Decimal
  user         User @relation(fields: [userId] , references: [id])
  @@unique([userId, asset])
}


enum Sides {
  LONG
  SHORT
}
model Position {
  id           String @id @default(uuid())
  userId       String
  marketId     String
  side         Sides
  qty          String
  entryPrice   String
  margin       String
  user         User @relation(fields: [userId], references: [id])
  @@unique([userId, marketId])
}